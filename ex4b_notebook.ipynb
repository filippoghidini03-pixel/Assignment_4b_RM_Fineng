    "# Visualize and compare the dendrogram and quasi-diagonalized correlation matrix \n",
    "# before and after detoning on the last rebalance date\n",
    "\n",
    "last_reb_date = all_dates[-1]\n",
    "universe_last = universes[last_reb_date]\n",
    "cov_last = covariances[last_reb_date][\"sample\"]\n",
    "\n",
    "# Compute correlation and distance matrices\n",
    "correlation_original = covariance_to_correlation(cov_last.values)\n",
    "correlation_detoned = detone(correlation_original, components_num=1)\n",
    "\n",
    "distance_original = correlation_to_hrp_distance(correlation_original)\n",
    "distance_detoned = correlation_to_hrp_distance(correlation_detoned)\n",
    "\n",
    "# Build linkage matrices\n",
    "linkage_original = hierarchical_clustering(\n",
    "    matrix=pd.DataFrame(distance_original, index=cov_last.index, columns=cov_last.columns),\n",
    "    linkage_method=\"ward\",\n",
    "    distance_metric=\"euclidean\",\n",
    ")\n",
    "\n",
    "linkage_detoned = hierarchical_clustering(\n",
    "    matrix=pd.DataFrame(distance_detoned, index=cov_last.index, columns=cov_last.columns),\n",
    "    linkage_method=\"ward\",\n",
    "    distance_metric=\"euclidean\",\n",
    ")\n",
    "\n",
    "# Plot dendrograms\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Original dendrogram\n",
    "leaves_original = sch.leaves_list(linkage_original.values)\n",
    "labels_original = [cov_last.index[i] for i in leaves_original]\n",
    "sch.dendrogram(linkage_original.values, labels=labels_original, ax=axes[0], \n",
    "               color_threshold=0, leaf_rotation=90)\n",
    "axes[0].set_title(\"Dendrogram - Original Correlation\")\n",
    "axes[0].set_ylabel(\"Distance\")\n",
    "\n",
    "# Detoned dendrogram\n",
    "leaves_detoned = sch.leaves_list(linkage_detoned.values)\n",
    "labels_detoned = [cov_last.index[i] for i in leaves_detoned]\n",
    "sch.dendrogram(linkage_detoned.values, labels=labels_detoned, ax=axes[1], \n",
    "               color_threshold=0, leaf_rotation=90)\n",
    "axes[1].set_title(\"Dendrogram - Detoned Correlation\")\n",
    "axes[1].set_ylabel(\"Distance\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Quasi-diagonalized correlation matrices\n",
    "def quasi_diagonalize_correlation(corr_matrix, leaves_list, asset_labels):\n",
    "    \"\"\"Reorder correlation matrix according to dendrogram leaf order.\"\"\"\n",
    "    reordered_indices = [asset_labels.get_loc(asset_labels[i]) for i in leaves_list]\n",
    "    reordered_corr = corr_matrix[np.ix_(reordered_indices, reordered_indices)]\n",
    "    reordered_labels = [asset_labels[i] for i in leaves_list]\n",
    "    return reordered_corr, reordered_labels\n",
    "\n",
    "reordered_corr_orig, labels_reord_orig = quasi_diagonalize_correlation(\n",
    "    correlation_original, leaves_original, cov_last.index\n",
    ")\n",
    "reordered_corr_det, labels_reord_det = quasi_diagonalize_correlation(\n",
    "    correlation_detoned, leaves_detoned, cov_last.index\n",
    ")\n",
    "\n",
    "# Plot heatmaps\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
    "\n",
    "im0 = axes[0].imshow(reordered_corr_orig, cmap=\"RdYlGn_r\", aspect=\"auto\", vmin=-1, vmax=1)\n",
    "axes[0].set_xticks(range(len(labels_reord_orig)))\n",
    "axes[0].set_yticks(range(len(labels_reord_orig)))\n",
    "axes[0].set_xticklabels(labels_reord_orig, rotation=90, fontsize=8)\n",
    "axes[0].set_yticklabels(labels_reord_orig, fontsize=8)\n",
    "axes[0].set_title(\"Quasi-Diagonalized Correlation - Original\")\n",
    "plt.colorbar(im0, ax=axes[0])\n",
    "\n",
    "im1 = axes[1].imshow(reordered_corr_det, cmap=\"RdYlGn_r\", aspect=\"auto\", vmin=-1, vmax=1)\n",
    "axes[1].set_xticks(range(len(labels_reord_det)))\n",
    "axes[1].set_yticks(range(len(labels_reord_det)))\n",
    "axes[1].set_xticklabels(labels_reord_det, rotation=90, fontsize=8)\n",
    "axes[1].set_yticklabels(labels_reord_det, fontsize=8)\n",
    "axes[1].set_title(\"Quasi-Diagonalized Correlation - Detoned\")\n",
    "plt.colorbar(im1, ax=axes[1])\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"INTUITION FOR DETONING:\")\n",
    "print(\"=\" * 60)\n",
    "print(\"Detoning removes the first principal component (market factor) from\")\n",
    "print(\"the correlation matrix. This factor typically drives all correlations\")\n",
    "print(\"upward uniformly, masking the underlying sector structure. By removing\")\n",
    "print(\"it, we expose idiosyncratic relationships, helping clustering identify\")\n",
    "print(\"more meaningful and stable groups of related assets.\")\n",
    "print(\"=\" * 60)"
