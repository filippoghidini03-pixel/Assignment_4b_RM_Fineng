   "source": [
    "LINK_GRID = [\"single\", \"ward\", \"complete\", \"average\"]\n",
    "ALLOC_GRID = {\n",
    "    \"recursive_bisection\": recursive_bisection,\n",
    "    \"dendrogram_iteration\": dendrogram_iteration,\n",
    "}\n",
    "\n",
    "# Compute HRP weights for all parameter combinations\n",
    "hrp_grid = {}\n",
    "for reb in all_dates:\n",
    "    for cov_key in COV_KEYS:\n",
    "        cov = covariances[reb][cov_key]\n",
    "        for link in LINK_GRID:\n",
    "            for alloc_name, alloc_func in ALLOC_GRID.items():\n",
    "                for detone_flag in DETONE_KEYS:\n",
    "                    weights = hierarchical_risk_parity(\n",
    "                        covariance=cov,\n",
    "                        linkage_method=link,\n",
    "                        distance_metric=DIST_METRIC,\n",
    "                        cluster_traverser=alloc_func,\n",
    "                        perform_detoning=detone_flag,\n",
    "                    )\n",
    "                    hrp_grid[(reb, cov_key, link, alloc_name, detone_flag)] = weights\n",
    "\n",
    "# Compute mean turnover and Herfindahl concentration index for each variant\n",
    "sensitivity_results = []\n",
    "\n",
    "for cov_key in COV_KEYS:\n",
    "    for link in LINK_GRID:\n",
    "        for alloc_name in ALLOC_GRID.keys():\n",
    "            for detone_flag in DETONE_KEYS:\n",
    "                # Gather weights across all rebalances for this configuration\n",
    "                weights_series = []\n",
    "                prev_weights = None\n",
    "                turnovers = []\n",
    "                concentrations = []\n",
    "                \n",
    "                for reb in all_dates:\n",
    "                    key = (reb, cov_key, link, alloc_name, detone_flag)\n",
    "                    weights = hrp_grid[key]\n",
    "                    weights_series.append(weights)\n",
    "                    \n",
    "                    # Compute turnover as sum of absolute weight changes\n",
    "                    if prev_weights is not None:\n",
    "                        # Align on common assets\n",
    "                        common = prev_weights.index.intersection(weights.index)\n",
    "                        if len(common) > 0:\n",
    "                            turnover = (prev_weights[common] - weights[common]).abs().sum()\n",
    "                            turnovers.append(turnover)\n",
    "                    \n",
    "                    # Compute Herfindahl concentration index (HHI)\n",
    "                    herfindahl = (weights ** 2).sum()\n",
    "                    concentrations.append(herfindahl)\n",
    "                    \n",
    "                    prev_weights = weights\n",
    "                \n",
    "                mean_turnover = np.mean(turnovers) if turnovers else np.nan\n",
    "                mean_concentration = np.mean(concentrations) if concentrations else np.nan\n",
    "                \n",
    "                sensitivity_results.append({\n",
    "                    \"Covariance\": cov_key,\n",
    "                    \"Linkage\": link,\n",
    "                    \"Allocator\": alloc_name,\n",
    "                    \"Detoning\": detone_flag,\n",
    "                    \"Mean Turnover\": mean_turnover,\n",
    "                    \"Mean Concentration (HHI)\": mean_concentration,\n",
    "                })\n",
    "\n",
    "sensitivity_df = pd.DataFrame(sensitivity_results)\n",
    "\n",
    "# Display results grouped by key dimensions\n",
    "print(\"\\nSENSITIVITY ANALYSIS: Mean Turnover and HHI Concentration\")\n",
    "print(\"=\" * 100)\n",
    "print(\"\\nGrouped by Linkage Method:\")\n",
    "print(sensitivity_df.groupby(\"Linkage\")[[\"Mean Turnover\", \"Mean Concentration (HHI)\"]].mean())\n",
    "\n",
    "print(\"\\nGrouped by Allocator:\")\n",
    "print(sensitivity_df.groupby(\"Allocator\")[[\"Mean Turnover\", \"Mean Concentration (HHI)\"]].mean())\n",
    "\n",
    "print(\"\\nGrouped by Covariance Estimator:\")\n",
    "print(sensitivity_df.groupby(\"Covariance\")[[\"Mean Turnover\", \"Mean Concentration (HHI)\"]].mean())\n",
    "\n",
    "print(\"\\nGrouped by Detoning:\")\n",
    "print(sensitivity_df.groupby(\"Detoning\")[[\"Mean Turnover\", \"Mean Concentration (HHI)\"]].mean())\n",
    "\n",
    "# Pivot tables for deeper analysis\n",
    "print(\"\\n\" + \"=\" * 100)\n",
    "print(\"\\nDETAILED ANALYSIS - Mean Turnover by Linkage × Allocator (no detoning):\")\n",
    "pivot_turnover = sensitivity_df[sensitivity_df[\"Detoning\"] == False].pivot_table(\n",
    "    values=\"Mean Turnover\", index=\"Linkage\", columns=\"Allocator\", aggfunc=\"mean\"\n",
    ")\n",
    "print(pivot_turnover)\n",
    "\n",
    "print(\"\\n\" + \"=\" * 100)\n",
    "print(\"\\nDETAILED ANALYSIS - Mean Concentration by Linkage × Allocator (no detoning):\")\n",
    "pivot_concentration = sensitivity_df[sensitivity_df[\"Detoning\"] == False].pivot_table(\n",
    "    values=\"Mean Concentration (HHI)\", index=\"Linkage\", columns=\"Allocator\", aggfunc=\"mean\"\n",
    ")\n",
    "print(pivot_concentration)"
   ]
