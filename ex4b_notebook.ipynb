    "def bt_turnover_series(weights_df):\n",
    "    \"\"\"Calculate turnover time series from portfolio weights.\"\"\"\n",
    "    turnover = []\n",
    "    prev_weights = None\n",
    "    for date, weights in weights_df.iterrows():\n",
    "        if prev_weights is not None:\n",
    "            common = prev_weights.index.intersection(weights.index)\n",
    "            if len(common) > 0:\n",
    "                turnover.append(\n",
    "                    (prev_weights[common] - weights[common]).abs().sum()\n",
    "                )\n",
    "        prev_weights = weights\n",
    "    return pd.Series(turnover, index=weights_df.index[1:])\n",
