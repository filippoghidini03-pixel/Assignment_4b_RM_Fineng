    "\n",
    "erc_l1_sample_vs_const = []\n",
    "erc_l1_sample_vs_mkt = []\n",
    "erc_l1_const_vs_mkt = []\n",
    "\n",
    "for reb in all_dates:\n",
    "    w_sample = erc_weights_by_estimator[\"sample\"][reb]\n",
    "    w_const = erc_weights_by_estimator[\"constant_corr\"][reb]\n",
    "    w_mkt = erc_weights_by_estimator[\"mkt_factor\"][reb]\n",
    "    \n",
    "    common = w_sample.index.intersection(w_const.index).intersection(w_mkt.index)\n",
    "    if len(common) > 0:\n",
    "        erc_l1_sample_vs_const.append(\n",
    "            (w_sample[common] - w_const[common]).abs().sum()\n",
    "        )\n",
    "        erc_l1_sample_vs_mkt.append(\n",
    "            (w_sample[common] - w_mkt[common]).abs().sum()\n",
    "        )\n",
    "        erc_l1_const_vs_mkt.append(\n",
    "            (w_const[common] - w_mkt[common]).abs().sum()\n",
    "        )\n",
    "\n",
    "print(\"\\nAverage L1 distance between ERC weights (same strategy, different estimators):\")\n",
