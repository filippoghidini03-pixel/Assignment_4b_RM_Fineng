    "erc_cumret = (1 + erc_backtest[\"returns\"]).cumprod() - 1\n",
    "hrp_cumret = (1 + hrp_backtest[\"returns\"]).cumprod() - 1\n",
    "axes[0, 0].plot(erc_cumret.index, erc_cumret.values, label=\"ERC\", linewidth=2)\n",
    "axes[0, 0].plot(hrp_cumret.index, hrp_cumret.values, label=\"HRP (representative)\", linewidth=2)\n",
