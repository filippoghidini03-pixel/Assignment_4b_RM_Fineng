    "axes[0, 1].grid(True, alpha=0.3)\n",
    "\n",
    "# Drawdown\n",
    "erc_cumret_series = (1 + erc_backtest[\"returns\"]).cumprod()\n",
    "erc_running_max = erc_cumret_series.expanding().max()\n",
