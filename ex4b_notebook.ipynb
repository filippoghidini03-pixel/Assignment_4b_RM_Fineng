    "def inverse_volatility_portfolio_local(covariance: np.ndarray) -> np.ndarray:\n",
    "    variances = np.diag(covariance)\n",
    "    std_devs = np.sqrt(variances)\n",
    "    inv_vol = 1.0 / std_devs\n",
    "    return inv_vol / inv_vol.sum()\n",
    "\n",
    "\n",
    "def equal_risk_contribution_portfolio_local(\n",
    "    covariance: np.ndarray,\n",
    "    initial_solution: np.ndarray | None = None,\n",
    "    options: dict | None = None,\n",
    ") -> np.ndarray:\n",
    "    if initial_solution is None:\n",
    "        initial_solution = inverse_volatility_portfolio_local(covariance)\n",
    "\n",
    "    def objective(weights: np.ndarray) -> float:\n",
    "        contributions = risk_contribution(weights.reshape(1, -1), covariance).flatten()\n",
    "        return np.sum((contributions - contributions.mean()) ** 2)\n",
    "\n",
    "    n = covariance.shape[0]\n",
    "    bounds = [(0.0, 1.0)] * n\n",
    "    constraints = ({\"type\": \"eq\", \"fun\": lambda w: np.sum(w) - 1.0},)\n",
    "\n",
    "    result = minimize(\n",
    "        objective,\n",
    "        x0=initial_solution,\n",
    "        bounds=bounds,\n",
    "        constraints=constraints,\n",
    "        options=options or {\"maxiter\": 500},\n",
    "    )\n",
    "    if not result.success:\n",
    "        raise ValueError(\"ERC optimization failed: \" + result.message)\n",
    "\n",
    "    return result.x"
