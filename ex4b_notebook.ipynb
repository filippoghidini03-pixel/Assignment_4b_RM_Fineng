    "            (w_const[common] - w_mkt[common]).abs().sum()\n",
    "        )\n",
    "\n",
    "avg_l1_sample_vs_const = np.mean(l1_distances_sample_vs_const)\n",
    "avg_l1_sample_vs_mkt = np.mean(l1_distances_sample_vs_mkt)\n",
    "avg_l1_const_vs_mkt = np.mean(l1_distances_const_vs_mkt)\n",
